# Example local MCP config
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=your_password
NEO4J_DB=neo4j

QDRANT_URL=http://localhost:6333
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_DOC=project_documents
QDRANT_COLLECTION_CODE="project_codes"

CODE_EMBEDDING_MODEL=jinaai/jina-embeddings-v3
TEXT_EMBEDDING_MODEL=BAAI/bge-m3

GLINER_MODEL_NAME=urchade/gliner_large-v2.1
#GLINER_MODEL_PATH=/Users/youruser/tool/ai/gliner_large-v2.1
HF_HUB_OFFLINE=0

EMBEDDING_DEVICE=cpu # cuda or mps or cpu

DEFAULT_ENTITY_TYPES=ORG,PRODUCT,STANDARD,TECH,CRYPTO,SECURITY,PROTOCOL,VEHICLE,DEVICE,SERVER,APP,CERTIFICATE,KEY
AZURE_OPENAI_API_KEY="xxxxxx"
AZURE_OPENAI_ENDPOINT="xxxx"
AZURE_OPENAI_DEPLOYMENT="xxx"
AZURE_OPENAI_API_VERSION="xxx"